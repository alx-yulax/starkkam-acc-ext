Функция ПолучитьПакетHTTPS(ПараметрыПодключения) 
	
	HTTPСоединение = Новый HTTPСоединение(ПараметрыПодключения.АдресСервера, 443, , , Новый ИнтернетПрокси(Ложь), 30,
		Новый ЗащищенноеСоединениеOpenSSL);

	HTTPЗапрос = Новый HTTPЗапрос(ПараметрыПодключения.ПутьСервиса);
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-Base-ID", ПараметрыПодключения.ИДБазы);
	HTTPЗапрос.Заголовки.Вставить("X-API-Key", ПараметрыПодключения.APIkey);
	
	Попытка
		HTTPОтвет = HTTPСоединение.ВызватьHTTPМетод("GET", HTTPЗапрос);
		ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		КодОтвета = HTTPОтвет.КодСостояния;
		
		Возврат Новый Структура("КодОтвета, ТелоОтвета", КодОтвета, ТелоОтвета);
	Исключение
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Ошибка отправки запроса: " + ОписаниеОшибки();
		Сообщение.Сообщить();
		Возврат Новый Структура("КодОтвета, ТелоОтвета", 555, ОписаниеОшибки());
	КонецПопытки;
	
КонецФункции


Процедура УдалитьНоменклатуруИзОчереди(МассивНоменклатуры)

	Для Каждого СсылкаНаНоменклатуру Из МассивНоменклатуры Цикл
