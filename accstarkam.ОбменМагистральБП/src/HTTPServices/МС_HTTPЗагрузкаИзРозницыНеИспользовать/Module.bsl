	Возврат XMLЗначение(Тип("СправочникСсылка.Склады"), "f2bbcd91-6b13-11e4-8756-000c29b3b732"); // fallback, Склад ЦМС
	
КонецФункции // ()

Процедура ЗаполнитьДоговор(ДокументОбъект)

	МассивВидовДоговоров = РаботаСДоговорамиКонтрагентовБПВызовСервера.ВидыДоговоровДокумента(
		Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Товары, ); //ДокументОбъект.ВидОперации//Тип("ДокументСсылка.ПоступлениеТоваровУслуг")
	
	РаботаСДоговорамиКонтрагентовБП.УстановитьДоговорКонтрагента(ДокументОбъект.ДоговорКонтрагента,
	ДокументОбъект.Контрагент, ДокументОбъект.Организация, МассивВидовДоговоров);	
	
КонецПроцедуры

Функция НайтиНоменклатуру(Данные)
	Если ЗначениеЗаполнено(Данные.guid_bp) Тогда
		Попытка
			Возврат XMLЗначение(Тип("СправочникСсылка.Номенклатура"), Данные.guid_bp)
		Исключение      
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
				"МС_ОбменРозницаБП",
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				"Ошибка поиска номенклатуры по guid_bp=" + Строка(Данные.guid_bp) + ": " + ОписаниеОшибки()
			);
		КонецПопытки
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция ПолучитьСтавкуНДС(СтавкаНДССтрока)
	Если СтавкаНДССтрока = "22%" Тогда
		Возврат Перечисления.СтавкиНДС.НДС22;
	ИначеЕсли СтавкаНДССтрока = "22% / 122%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС22_122;
	ИначеЕсли СтавкаНДССтрока = "5%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС5;
	ИначеЕсли СтавкаНДССтрока = "5% / 105%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС5_105;
	ИначеЕсли СтавкаНДССтрока = "20%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС20;
	ИначеЕсли СтавкаНДССтрока = "18%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС18;
	ИначеЕсли СтавкаНДССтрока = "18% / 118%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС18_118;
	ИначеЕсли СтавкаНДССтрока = "10%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС10;
	ИначеЕсли СтавкаНДССтрока = "10% / 110%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС10_110;
	ИначеЕсли СтавкаНДССтрока = "0%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС0;
	ИначеЕсли СтавкаНДССтрока = "Без НДС" Тогда	
		Возврат Перечисления.СтавкиНДС.БезНДС;
	ИначеЕсли СтавкаНДССтрока = "7%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС7;
	ИначеЕсли СтавкаНДССтрока = "7% / 107%" Тогда	
		Возврат Перечисления.СтавкиНДС.НДС7_107;
	Иначе
		Возврат Перечисления.СтавкиНДС.БезНДС;
	КонецЕсли;
КонецФункции

Процедура ЗаполнитьТабличнуюЧастьТовары(Товары, Данные)
	Товары.Очистить();
	
	Для каждого СтрокаТЧ Из Данные Цикл 
		
		НоваяСтрока = Товары.Добавить();
		НоваяСтрока.Номенклатура = НайтиНоменклатуру(СтрокаТЧ.Nomenclature);
		НоваяСтрока.Количество = СтрокаТЧ.quantity;
		НоваяСтрока.Цена = СтрокаТЧ.price;
		НоваяСтрока.Сумма = СтрокаТЧ.amount;
		НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТЧ.vat_rate);
		НоваяСтрока.СуммаНДС = СтрокаТЧ.vat_amount;
		
		НоваяСтрока.СтранаПроисхождения = НоваяСтрока.Номенклатура.СтранаПроисхождения;

	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьТабличнуюЧастьТоварыСчетНаОплатуПоставщика(Товары, Данные)
	Товары.Очистить();
	
	Для каждого СтрокаТЧ Из Данные Цикл 
		
		НоваяСтрока = Товары.Добавить();
		НоваяСтрока.Номенклатура = НайтиНоменклатуру(СтрокаТЧ.Nomenclature);
		НоваяСтрока.Количество = СтрокаТЧ.quantity;
		НоваяСтрока.Цена = СтрокаТЧ.price;
		НоваяСтрока.Сумма = СтрокаТЧ.amount;
		НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНДС(СтрокаТЧ.vat_rate);
		НоваяСтрока.СуммаНДС = СтрокаТЧ.vat_amount;

	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДокументДаннымиИзРозницы(ДокументОбъект, Данные)
	
	ДокументОбъект.Организация	= НайтиОрганизацию(Данные.organization);
	ДокументОбъект.Контрагент	= НайтиКонтрагента(Данные.Counterparty);
	
	ЗаполнениеДокументов.Заполнить(ДокументОбъект, , Истина);
	
	ЗаполнитьДоговор(ДокументОбъект);
	
	ДокументОбъект.Дата = ДатаИзСтрокиJSON(Данные.date); 
	ДокументОбъект.ДатаВходящегоДокумента = ДатаИзСтрокиJSON(Данные.incoming_date); 
	ДокументОбъект.Склад = НайтиСклад(Данные.warehouse);
	ДокументОбъект.НомерВходящегоДокумента = Данные.incoming_number;
	ДокументОбъект.Комментарий = Данные.comment;	
	ДокументОбъект.ЭтоУниверсальныйДокумент = Данные.is_upd;
	ДокументОбъект.СуммаВключаетНДС = Данные.amount_includes_vat;
	ДокументОбъект.СуммаДокумента = Данные.total_amount;
	ДокументОбъект.ЕстьМаркируемаяПродукцияГИСМ = Данные.GISM;
	ДокументОбъект.СпособЗачетаАвансов = Перечисления.СпособыЗачетаАвансов.НеЗачитывать;
	
	ЗаполнитьТабличнуюЧастьТовары(ДокументОбъект.Товары, Данные.items);
	
КонецПроцедуры

Процедура ЗаполнитьСчетНаОплатуПоставщикаДаннымиИзРозницы(ДокументОбъект, Данные)
	
	ДокументОбъект.Организация	= НайтиОрганизацию(Данные.organization);
	ДокументОбъект.Контрагент	= НайтиКонтрагента(Данные.Counterparty);
	
	ЗаполнениеДокументов.Заполнить(ДокументОбъект);
	
	ЗаполнитьДоговор(ДокументОбъект);
	
	ДокументОбъект.Дата = ДатаИзСтрокиJSON(Данные.date); 
	ДокументОбъект.ДатаВходящегоДокумента = ДатаИзСтрокиJSON(Данные.incoming_date); 
	ДокументОбъект.НомерВходящегоДокумента = Данные.incoming_number;
	ДокументОбъект.Комментарий = Данные.comment;	
	ДокументОбъект.СуммаВключаетНДС = Данные.amount_includes_vat;
	ДокументОбъект.СуммаДокумента = Данные.total_amount;
	
	ЗаполнитьТабличнуюЧастьТоварыСчетНаОплатуПоставщика(ДокументОбъект.Товары, Данные.items);
	
КонецПроцедуры

Процедура ЗаписатьВРегистрСоответствияОбъектов(СобственнаяСсылка, СсылкаВДругойИБ, ИмяТипаПриемника)
	Если ЗначениеЗаполнено(СобственнаяСсылка) Тогда
		Запись = РегистрыСведений.МС_СоответствиеОбъектовДляОбмена.СоздатьМенеджерЗаписи();
		Запись.СобственнаяСсылка = СобственнаяСсылка;
		Запись.СсылкаВДругойИБ = СсылкаВДругойИБ;
		Запись.ИмяТипаПриемника = ИмяТипаПриемника;
		Запись.Записать(Истина);
	КонецЕсли;
КонецПроцедуры

Функция СоздатьПоступлениеТоваровУслугИзРозницы(Данные)
	ИмяТипаПриемника = "ДокументСсылка.ПоступлениеТоваровУслуг";
	ДокументСсылка = НайтиПоСсылкеВДругойБазе(Данные.guid, ИмяТипаПриемника);
	ДобавитьВСоответствиеОбъектов = Ложь;
	
	Если ДокументСсылка = ПолучитьПустуюСсылкуПоТипу(ИмяТипаПриемника) Тогда
		ДобавитьВСоответствиеОбъектов = Истина;
		ДокументОбъект = СоздатьНовыйОбъектПоТипу(ИмяТипаПриемника);
	Иначе
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьДокументДаннымиИзРозницы(ДокументОбъект, Данные); 
	
	ЗаполнениеДокументов.Заполнить(ДокументОбъект, , Истина); //удалять нельзя
	
	ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
	
	Если ДобавитьВСоответствиеОбъектов Тогда
		ЗаписатьВРегистрСоответствияОбъектов(ДокументОбъект.Ссылка, Данные.guid, ИмяТипаПриемника);
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("success", Истина);
	Результат.Вставить("created", ДобавитьВСоответствиеОбъектов);
	Результат.Вставить("document_ref", Строка(ДокументОбъект.Ссылка));
	Результат.Вставить("document_number", ДокументОбъект.Номер);
	Результат.Вставить("message", ?(ДобавитьВСоответствиеОбъектов, "Документ Поступление товаров и услуг создан", "Документ Поступление товаров и услуг обновлен"));
	Результат.Вставить("ref", ПолучитьНавигационнуюСсылку(ДокументОбъект.Ссылка));
	Возврат Результат;
	
КонецФункции

