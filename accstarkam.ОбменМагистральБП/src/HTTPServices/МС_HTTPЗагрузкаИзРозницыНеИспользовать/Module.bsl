
#Область ОбработчикиСобытий

Функция ПриемПоступленияТоваровУслугИзРозницы(Запрос)
	возврат 0;
	
	Попытка
		
		Данные = Неопределено;
		
		Если Запрос.HTTPМетод <> "POST" Тогда
			Возврат ОтветJSON(405, Новый Структура("success,error", Ложь, "Разрешен только POST"));
		КонецЕсли;
		
		ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		
		Если ПустаяСтрока(ТелоЗапроса) Тогда
			Возврат ОтветJSON(400, Новый Структура("success,error", Ложь, "Пустое тело запроса"));
		КонецЕсли;
		
		Попытка
			Данные = ПрочитатьJSONИзСтроки(ТелоЗапроса);
		Исключение
			Возврат ОтветJSON(400, Новый Структура("success,error", Ложь, "Некорректный JSON: " + ОписаниеОшибки()));
		КонецПопытки;
		
		СообщениеОбОшибке = "";
		Если Не ПроверитьВходящийJSON(Данные, СообщениеОбОшибке) Тогда
			Возврат ОтветJSON(400, Новый Структура("success,error", Ложь, СообщениеОбОшибке));
		КонецЕсли;
		
		НачатьТранзакцию();
		
		Попытка
			
			ЗаблокироватьЗагрузкуПоGUID(Данные.guid);
			Если Данные.source =  "ПриходнаяНакладная" Тогда
				Результат = СоздатьПоступлениеТоваровУслугИзРозницы(Данные);
			ИначеЕсли Данные.source =  "СчетНаОплатуПоставщика" Тогда
				Результат = СоздатьСчетНаОплатуПоставщикаИзРозницы(Данные);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			ВызватьИсключение;
			
		КонецПопытки;
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"МС_ОбменРозницаБП",
			УровеньЖурналаРегистрации.Информация,
			,
			,
			"Загрузка поступления из Розницы завершена (guid=" + Строка(Данные.guid)
				+ ", created=" + ?(Результат.created, "true", "false")
				+ ", ref=" + Строка(Результат.document_ref)
				+ ", number=" + Строка(Результат.document_number) + ")."
		);
		
		Возврат ОтветJSON(200, Результат);
		
	Исключение
		
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"МС_ОбменРозницаБП",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			"Ошибка загрузки поступления из Розницы (guid=" + ?(Данные = Неопределено Или Данные = Null, "?", Строка(ЗначениеСвойства(Данные, "guid", "?"))) + "): " + ОписаниеОшибки()
		);
		
		Возврат ОтветJSON(
			500,
			Новый Структура(
				"success,error",
				Ложь,
				ОписаниеОшибки()
			)
		);
		
	КонецПопытки;
КонецФункции


Функция НоменклатураЗагрузитьНоменклатуру(Запрос)
	
	Возврат 0;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Возврат Ответ;
КонецФункции
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОтветJSON(КодСостояния, Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	ЗаписатьJSON(ЗаписьJSON, Данные);
	
	СтрокаJSON = ЗаписьJSON.Закрыть();
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	
	Возврат Ответ;
	
КонецФункции

Функция ЭтоНезаполненнаяСтрока(Знач Значение)
	Если Значение = Неопределено Или Значение = Null Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат ПустаяСтрока(СокрЛП(Строка(Значение)));
КонецФункции

Функция ЗначениеСвойства(Данные, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	Если Данные = Неопределено Или Данные = Null Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если Данные.Свойство(ИмяСвойства) Тогда
		Возврат Данные[ИмяСвойства];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПроверитьВходящийJSON(Данные, СообщениеОбОшибке)
	
	СообщениеОбОшибке = "";
	
	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		СообщениеОбОшибке = "Ожидается JSON-объект верхнего уровня.";
		Возврат Ложь;
	КонецЕсли;
	
	GUIDДокументаИсточник = ЗначениеСвойства(Данные, "guid", "");
	Если ЭтоНезаполненнаяСтрока(GUIDДокументаИсточник) Тогда
		СообщениеОбОшибке = "Не заполнено поле guid.";
		Возврат Ложь;
	КонецЕсли;
	
	Организация = ЗначениеСвойства(Данные, "organization", Неопределено);
	Если ТипЗнч(Организация) <> Тип("Структура") Тогда
		СообщениеОбОшибке = "Не заполнено поле organization.";
		Возврат Ложь;
	КонецЕсли;
	
	Товары = ЗначениеСвойства(Данные, "items", Неопределено);
	Если ТипЗнч(Товары) <> Тип("Массив") Тогда
		СообщениеОбОшибке = "Не заполнено поле items (ожидается массив).";
		Возврат Ложь;
	КонецЕсли;
	
	Если Товары.Количество() = 0 Тогда
		СообщениеОбОшибке = "Поле items пустое.";
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаблокироватьЗагрузкуПоGUID(Знач GUIDДокумента)
	
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.МС_СоответствиеОбъектовДляОбмена");
	ЭлементБлокировкиДанных.УстановитьЗначение("СсылкаВДругойИБ", GUIDДокумента);
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	Попытка
		БлокировкаДанных.Заблокировать();
	Исключение
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"МС_ОбменРозницаБП",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			"Ошибка блокировки загрузки по GUID=" + Строка(GUIDДокумента) + ": " + ОписаниеОшибки()
		);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Попытка
		Данные = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		ВызватьИсключение;
	КонецПопытки;
	
	ЧтениеJSON.Закрыть();
	
	Возврат Данные;
	
КонецФункции

Функция ДатаИзСтрокиJSON(Знач ЗначениеJSON) 
	
	Если ЗначениеJSON = Неопределено Или ЗначениеJSON = Null Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ЗначениеJSON) = Тип("Дата") Тогда
		Возврат ЗначениеJSON;
	КонецЕсли;
	
	СтрокаДаты = СокрЛП(Строка(ЗначениеJSON));
	
	Если ПустаяСтрока(СтрокаДаты) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат XMLЗначение(Тип("Дата"), СтрокаДаты);

КонецФункции

Функция ПолучитьПустуюСсылкуПоТипу(ТипСсылки) 
	
	ИмяТипа = Строка(ТипСсылки);
	
	Если СтрНачинаетсяС(ИмяТипа, "СправочникСсылка.") Тогда
		ИмяОбъекта = СтрЗаменить(ИмяТипа, "СправочникСсылка.", "");
		Возврат Справочники[ИмяОбъекта].ПустаяСсылка();
	КонецЕсли;
	
	Если СтрНачинаетсяС(ИмяТипа, "ДокументСсылка.") Тогда
		ИмяОбъекта = СтрЗаменить(ИмяТипа, "ДокументСсылка.", "");
		Возврат Документы[ИмяОбъекта].ПустаяСсылка();
	КонецЕсли;
	
	ВызватьИсключение "Неподдерживаемый тип ссылки: " + ИмяТипа;
	
КонецФункции

Функция СоздатьНовыйОбъектПоТипу(ТипСсылки) 
	
	ИмяТипа = Строка(ТипСсылки);
	
	Если СтрНачинаетсяС(ИмяТипа, "СправочникСсылка.") Тогда
		ИмяОбъекта = СтрЗаменить(ИмяТипа, "СправочникСсылка.", "");
		Возврат Справочники[ИмяОбъекта].СоздатьЭлемент();
	КонецЕсли;
	
	Если СтрНачинаетсяС(ИмяТипа, "ДокументСсылка.") Тогда
		ИмяОбъекта = СтрЗаменить(ИмяТипа, "ДокументСсылка.", "");
		Возврат Документы[ИмяОбъекта].СоздатьДокумент();
	КонецЕсли;
	
	ВызватьИсключение "Неподдерживаемый тип ссылки: " + ИмяТипа;
	
КонецФункции

Функция НайтиПоСсылкеВДругойБазе(СсылкаВДругойИБ, ИмяТипаПриемника)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МС_СоответствиеОбъектовДляОбмена.СобственнаяСсылка КАК СобственнаяСсылка
	|ИЗ
	|	РегистрСведений.МС_СоответствиеОбъектовДляОбмена КАК МС_СоответствиеОбъектовДляОбмена
	|ГДЕ
	|	МС_СоответствиеОбъектовДляОбмена.СсылкаВДругойИБ = &СсылкаВДругойИБ
	|	И МС_СоответствиеОбъектовДляОбмена.ИмяТипаПриемника = &ИмяТипаПриемника";
	
	Запрос.УстановитьПараметр("СсылкаВДругойИБ", СсылкаВДругойИБ);
	Запрос.УстановитьПараметр("ИмяТипаПриемника", ИмяТипаПриемника);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.СобственнаяСсылка;
	КонецЕсли;
	
	Возврат ПолучитьПустуюСсылкуПоТипу(ИмяТипаПриемника);
	
КонецФункции 

Функция НайтиПоИННКПП(ИНН, КПП, ИмяТипа)
    	
	ИНН = СокрЛП(ИНН);
	КПП = СокрЛП(КПП);
	
	ИмяОбъекта = СтрЗаменить(ИмяТипа, "СправочникСсылка.", "");
	
	Если ПустаяСтрока(ИНН) Тогда
		Возврат Справочники[ИмяОбъекта].ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Организации.Ссылка КАК Ссылка,
	|	Организации.ИНН КАК ИНН,
	|	Организации.КПП КАК КПП,
	|	ВЫБОР
	|		КОГДА Организации.КПП = &КПП
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК Приоритет
	|ИЗ
	|	Справочник." + ИмяОбъекта + " КАК Организации
	|ГДЕ
	|	Организации.ПометкаУдаления = ЛОЖЬ
	|	И Организации.ИНН = &ИНН
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет";
	
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("КПП", КПП);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники[ИмяОбъекта].ПустаяСсылка();

КонецФункции 

Функция НайтиОрганизацию(Данные)
	
	ИмяТипаПриемника = "СправочникСсылка.Организации";
	Организация = НайтиПоСсылкеВДругойБазе(Данные.guid, ИмяТипаПриемника);
	Если Организация = ПолучитьПустуюСсылкуПоТипу(ИмяТипаПриемника) Тогда
		Организация = НайтиПоИННКПП(Данные.inn, Данные.kpp, ИмяТипаПриемника);
		ЗаписатьВРегистрСоответствияОбъектов(Организация, Данные.guid, ИмяТипаПриемника);
	КонецЕсли;
	
	Возврат Организация;	
	
КонецФункции

Функция НайтиКонтрагента(Данные)
	
	ИмяТипаПриемника = "СправочникСсылка.Контрагенты";
	Контрагент = НайтиПоСсылкеВДругойБазе(Данные.guid, ИмяТипаПриемника);
	Если Контрагент = ПолучитьПустуюСсылкуПоТипу(ИмяТипаПриемника) Тогда
		Контрагент = НайтиПоИННКПП(Данные.inn, Данные.kpp, ИмяТипаПриемника);
		ЗаписатьВРегистрСоответствияОбъектов(Контрагент, Данные.guid, ИмяТипаПриемника);
	КонецЕсли; 
	
	Возврат Контрагент;
	
КонецФункции 

Функция НайтиСклад(ДанныеСклада)
	//Склад.Вставить("guid", ГУИД(ДокументСсылка.СтруктурнаяЕдиница));
	//Склад.Вставить("name", ДокументСсылка.СтруктурнаяЕдиница.Наименование);
	
